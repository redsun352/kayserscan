<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kayser_background">

    <com.google.android.material.navigationrail.NavigationRailView
        android:id="@+id/navigationRailView"
        android:layout_width="56dp"
        android:layout_height="0dp"
        app:labelVisibilityMode="unlabeled"
        app:menu="@menu/area_scan_navigation_menu"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.kayser.areascan.render.widgets.ModelSurfaceView
        android:id="@+id/mGLView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/navigationRailView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_default="percent"
        app:layout_constraintHeight_percent="0.78" />

    <TextView
        android:id="@+id/lastValueTextview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="#88000000"
        android:padding="6dp"
        android:textColor="@android:color/white"
        android:textSize="13sp"
        app:layout_constraintTop_toTopOf="@id/mGLView"
        app:layout_constraintEnd_toEndOf="@id/mGLView" />

    <FrameLayout
        android:id="@+id/settingsContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/kayser_surface"
        app:layout_constraintTop_toBottomOf="@id/mGLView"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/navigationRailView"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/cameraRotationResetButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:fabCustomSize="36dp"
        app:srcCompat="@android:drawable/ic_menu_revert"
        app:layout_constraintTop_toTopOf="@id/mGLView"
        app:layout_constraintEnd_toEndOf="@id/mGLView" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/cameraZoomResetButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:fabCustomSize="36dp"
        app:srcCompat="@android:drawable/ic_menu_zoom"
        app:layout_constraintTop_toTopOf="@id/mGLView"
        app:layout_constraintEnd_toStartOf="@id/cameraRotationResetButton" />

</androidx.constraintlayout.widget.ConstraintLayout>
